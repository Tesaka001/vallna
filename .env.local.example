# Vallna — environment variables
# Copy this file to `.env.local` and fill in values as each build step is reached.
# NEVER commit `.env.local`. See _docs/01_vallna_technical_design_v1_3.md §7.3.

# --- Supabase (Step 2) ---
# Project hosted in EU region (Frankfurt / eu-central-1).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only. Never expose to the client.
SUPABASE_SERVICE_ROLE_KEY=

# --- Anthropic Claude API (Step 8) ---
ANTHROPIC_API_KEY=
# Optional model overrides (defaults match LLM architecture doc)
# ANTHROPIC_MODEL_TIER1=claude-haiku-4-5
# ANTHROPIC_MODEL_TIER2=claude-sonnet-4-6
# ANTHROPIC_MODEL_TIER3=claude-opus-4-6

# --- Cron (Step 8) ---
# Secret for Vercel cron / manual trigger: Authorization: Bearer <CRON_SECRET>
CRON_SECRET=

# --- Resend email (Step 9) ---
RESEND_API_KEY=
# Verified sender in Resend (defaults to onboarding@resend.dev for dev)
# RESEND_FROM_EMAIL=Vallna <reports@yourdomain.com>

# --- Web Push (Step 9) ---
# Generate with: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:hello@yourdomain.com

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
